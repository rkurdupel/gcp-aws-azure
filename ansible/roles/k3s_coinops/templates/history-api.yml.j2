apiVersion: apps/v1
kind: Deployment
metadata:
  name: history-api
  namespace: "{{ coinops_namespace }}"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: history-api
  template:
    metadata:
      labels:
        app: history-api
    spec:
      containers:
        - name: history-api
          image: "rkurdupel/coin-ops-history-api:v1"
          imagePullPolicy: Always
          ports:
            - containerPort: {{ coinops_history_port }}
          envFrom:
            - secretRef:
                name: coinops-secrets
          readinessProbe:
            httpGet:
              path: /health
              port: {{ coinops_history_port }}
            initialDelaySeconds: 10
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /health
              port: {{ coinops_history_port }}
            initialDelaySeconds: 15
            periodSeconds: 15
---
apiVersion: v1
kind: Service
metadata:
  name: history-api
  namespace: "{{ coinops_namespace }}"
spec:
  selector:
    app: history-api
  ports:
    - port: {{ coinops_history_port }}
      targetPort: {{ coinops_history_port }}