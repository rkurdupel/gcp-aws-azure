apiVersion: v1
kind: Secret
metadata:
  name: coinops-secrets
  namespace: {{ coinops_namespace }}
type: Opaque
stringData:
  DATABASE_URL: "postgresql://{{coinops_db_user}}:{{coinops_db_password}}@postgres:5432/{{coinops_db_name}}"
  RUNTIME_BACKEND: "{{coinops_runtime_backend}}"
  POSTGRES_USER: "{{ coinops_db_user }}"
  POSTGRES_PASSWORD: "{{ coinops_db_password }}"
  POSTGRES_DB: "{{ coinops_db_name }}"
  RABBITMQ_URL: "amqp://{{ rabbitmq_user }}:{{ rabbitmq_password }}@rabbitmq:5672/"
  REDIS_URL: "redis://:{{ redis_password }}@redis:6379/0"
