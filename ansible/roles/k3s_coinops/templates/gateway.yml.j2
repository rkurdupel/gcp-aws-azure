apiVersion: v1
kind: ConfigMap
metadata:
  name: gateway-config
  namespace: "{{ coinops_namespace }}"
data:
  default.conf: |
    server {
        listen 80;
        server_name _;

        location /api/ {
            proxy_pass http://proxy:{{ coinops_proxy_port }}/;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        location /history-api/ {
            proxy_pass http://history-api:{{ coinops_history_port }}/;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        location / {
            proxy_pass http://ui:80/;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
        }

        location /health {
            return 200 '{"status":"ok"}';
            add_header Content-Type application/json;
        }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  namespace: "{{ coinops_namespace }}"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      containers:
        - name: gateway
          image: nginx:alpine
          ports:
            - containerPort: 80
          volumeMounts:
            - name: gateway-config
              mountPath: /etc/nginx/conf.d/default.conf
              subPath: default.conf
          readinessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 10
            periodSeconds: 15
      volumes:
        - name: gateway-config
          configMap:
            name: gateway-config
---
apiVersion: v1
kind: Service
metadata:
  name: gateway
  namespace: "{{ coinops_namespace }}"
spec:
  selector:
    app: gateway
  ports:
    - port: 80
      targetPort: 80