apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: redis
  namespace: "{{ coinops_namespace }}"
spec:
  selector:
    matchLabels:
      app: redis
  serviceName: redis
  replicas: 1
  template:
    metadata:
      labels:
        app: redis
    spec:
      containers:
        - name: redis
          image: redis:7-alpine
          command:
            - redis-server
            - --requirepass
            - "{{ redis_password }}"
          ports:
            - containerPort: 6379
          readinessProbe:
            exec:
              command:
                - redis-cli
                - -a
                - "{{ redis_password }}"
                - ping
            initialDelaySeconds: 10
            periodSeconds: 5
          volumeMounts:
            - name: redis-data
              mountPath: /data
  volumeClaimTemplates:
    - metadata:
        name: redis-data
      spec:
        accessModes: [ReadWriteOnce]
        storageClassName: "{{ coinops_storage_class }}"
        resources:
          requests:
            storage: "{{ redis_storage }}"
---
apiVersion: v1
kind: Service
metadata:
  name: redis
  namespace: "{{ coinops_namespace }}"
spec:
  selector:
    app: redis
  ports:
    - port: 6379
      targetPort: 6379