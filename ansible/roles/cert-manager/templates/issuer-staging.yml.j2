# staging issuer manifest
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ cert_manager_issuer_staging_name }}
spec:
  acme:
    email: {{ cert_manager_acme_email }}
    server: {{ cert_manager_acme_url_staging }}
    privateKeySecretRef:
      name: {{ cert_manager_issuer_staging_name }}-account-key
    solvers:
      - dns01:
          cloudflare:
            apiTokenSecretRef:
              name: cloudflare-api-token-secret
              key: api-token